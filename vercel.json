{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/chiropraxie.html",
      "destination": "/osteopathe.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-clermont-l-herault.html",
      "destination": "/osteopathe-proche-clermont-l-herault.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-gignac.html",
      "destination": "/osteopathe-proche-gignac.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-saint-andre-de-sangonis.html",
      "destination": "/osteopathe-proche-saint-andre-de-sangonis.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-paulhan.html",
      "destination": "/osteopathe-proche-paulhan.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-aspiran.html",
      "destination": "/osteopathe-proche-aspiran.html",
      "permanent": true
    },
    {
      "source": "/osteopathe-proche-saint-leonard-de-noblat.html",
      "destination": "/osteopathe-proche-clermont-l-herault.html",
      "permanent": true
    },
    {
      "source": "/osteopathe-proche-eymoutiers.html",
      "destination": "/osteopathe-proche-gignac.html",
      "permanent": true
    },
    {
      "source": "/osteopathe-proche-chateauneuf-la-foret.html",
      "destination": "/osteopathe-proche-saint-andre-de-sangonis.html",
      "permanent": true
    },
    {
      "source": "/osteopathe-proche-peyrat-le-chateau.html",
      "destination": "/osteopathe-proche-paulhan.html",
      "permanent": true
    },
    {
      "source": "/osteopathe-proche-panazol-limoges-est.html",
      "destination": "/osteopathe-proche-aspiran.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)\\.(css|js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)\\.(woff2|png|jpg|jpeg|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
