{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "cleanUrls": false,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*\\.(?:html|xml|txt|ico|png))",
      "dest": "/public/$1"
    },
    {
      "src": "/$",
      "dest": "/public/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-saint-leonard-de-noblat.html",
      "destination": "/chiropracteur-proche-clermont-l-herault.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-eymoutiers.html",
      "destination": "/chiropracteur-proche-gignac.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-chateauneuf-la-foret.html",
      "destination": "/chiropracteur-proche-saint-andre-de-sangonis.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-peyrat-le-chateau.html",
      "destination": "/chiropracteur-proche-paulhan.html",
      "permanent": true
    },
    {
      "source": "/chiropracteur-proche-panazol-limoges-est.html",
      "destination": "/chiropracteur-proche-aspiran.html",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
